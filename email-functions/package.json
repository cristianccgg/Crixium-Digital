{
  "name": "email-functions",
  "version": "1.0.0",
  "description": "Firebase Functions para envío de correos",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions:sendOrderConfirmationEmail,functions:sendOrderStatusEmail,functions:onOrderPaymentStatusChange,functions:sendGenericEmail",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "firebase-admin": "^11.11.0",
    "firebase-functions": "^6.3.2",
    "nodemailer": "^6.9.7"
  },
  "private": true
}
