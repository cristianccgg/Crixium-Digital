{
  "redirects": [
    {
      "source": "/blog/essential-elements-music-company-website",
      "destination": "/en/blog/essential-elements-music-company-website",
      "permanent": true
    },
    {
      "source": "/blog/professional-sound-identity-digital-presence",
      "destination": "/en/blog/professional-sound-identity-digital-presence",
      "permanent": true
    },
    {
      "source": "/blog/web-design-conversions-music-services",
      "destination": "/en/blog/web-design-conversions-music-services",
      "permanent": true
    },
    {
      "source": "/blog/web-design-trends-production-studios-2025",
      "destination": "/en/blog/web-design-trends-production-studios-2025",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
